# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will NOT be committed.

# ── GrayHatWarfare API (required) ─────────────────────────────────────────
# Get yours at: https://buckets.grayhatwarfare.com/
GRAYHATWARFARE_API_KEY=your_api_key_here

# ── Dashboard authentication (recommended for any non-localhost deployment) ─
# Set a strong random secret; requests without this token will be rejected.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to run unauthenticated (localhost / trusted network only).
DASHBOARD_SECRET=

# ── CORS allowed origins ───────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser requests.
# Examples:
#   ALLOWED_ORIGINS=https://myapp.example.com,https://dashboard.example.com
# Leave empty to restrict to same-origin only (recommended for production).
# Set to "*" only for local development.
ALLOWED_ORIGINS=

# ── Logging ────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR  (default: INFO)
LOG_LEVEL=INFO
# Optional log file path (leave empty to log to stdout only)
LOG_FILE=

# ── AI Analysis (optional) ────────────────────────────────────────────────
# Supply one of these to enable the AI bucket classification feature.
# These are loaded from env so keys are never passed over the network.

# Hugging Face Inference API token (free tier works)
# Get yours at: https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=hf_...

# OpenAI API key
# OPENAI_API_KEY=sk-...
